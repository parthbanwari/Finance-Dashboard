DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# MongoDB — full connection URI (database name can be in the path).
# Local: mongodb://127.0.0.1:27017/finance_dashboard
# Atlas: mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/finance_dashboard?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/finance_dashboard
# Optional: leave empty to use the database name from the URI path only.
MONGODB_NAME=

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Extra CORS origins (comma-separated, no trailing slash). Local Vite + deployed Vercel defaults
# are merged in settings; use this for preview deploys or extra domains.
# Example: https://my-app-git-main-team.vercel.app
CORS_ALLOWED_ORIGINS=

# Optional: override deployed SPA origins (comma-separated). Defaults include production Vercel.
# CORS_DEPLOYED_DEFAULT_ORIGINS=https://finance-dashboard-frontend-fawn.vercel.app

# Email OTP sign-in: dev uses console backend (code printed to terminal).
# For real mail, set EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend and SMTP vars.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Finance Dashboard <noreply@localhost>

OTP_LOGIN_TTL_SECONDS=600
OTP_LOGIN_RATE_LIMIT_SECONDS=60

# Set to 1 only when generating migrations without MongoDB running (uses dummy DB engine).
# DJANGO_USE_DUMMY_DB=0
