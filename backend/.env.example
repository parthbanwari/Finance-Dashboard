DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# MySQL must match Django migrations. If APIs 500 with "Unknown column" or
# "Table doesn't exist", see SETUP_DATABASE.txt and run: python manage.py db_status
DB_NAME=finance_dashboard
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Comma-separated origins for the SPA (e.g. Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email OTP sign-in: dev uses console backend (code printed to terminal).
# For real mail, set EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend and SMTP vars.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Finance Dashboard <noreply@localhost>

OTP_LOGIN_TTL_SECONDS=600
OTP_LOGIN_RATE_LIMIT_SECONDS=60
